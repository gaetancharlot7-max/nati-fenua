# Ignore uploaded media files - these are large binary assets that should not
# be copied into the build context. Their presence causes Railpack to schedule
# an extra file-copy step which triggers a second (corrupted) pip install phase,
# resulting in the "ip install / sh: 1: ip: not found" build failure.
uploads/

# Ignore test files - not needed at runtime and add unnecessary build context.
tests/

# Ignore local development and CI artefacts.
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
*.egg-info/
.env
.env.*
